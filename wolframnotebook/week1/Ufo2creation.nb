Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"p2", ",", "t", ",", 
       OverscriptBox["uv", "\<\"-\"\>"]}], "}"}], ",", 
     FractionBox[
      RowBox[{"3", " ", 
       SuperscriptBox["lam1", "2"], " ", 
       RowBox[{"(", 
        RowBox[{
         SuperscriptBox["MPe2", "2"], "-", 
         SuperscriptBox["MT", "2"], "-", 
         SuperscriptBox["Muv", "2"]}], ")"}], " ", 
       SqrtBox[
        RowBox[{
         SuperscriptBox["MPe2", "4"], "+", 
         SuperscriptBox[
          RowBox[{"(", 
