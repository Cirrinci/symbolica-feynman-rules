Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"-", 
    FractionBox["1", "2"]}], " ", 
   SuperscriptBox["MM1", "2"], " ", 
   SuperscriptBox["pi1", "2"]}], "+", 
  RowBox[{
   FractionBox["1", "2"], " ", 
   SuperscriptBox[
    RowBox[{
     SubscriptBox["\"\<\[PartialD]\>\"", "mu"], "[", "pi1", "]"}], 
