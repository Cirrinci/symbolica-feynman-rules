Cell["Fermionic Lagrangian", "Text",
 CellChangeTimes->{{3.9816929374055862`*^9, 
  3.9816929440394382`*^9}},ExpressionUUID->"e406e0ac-5850-4e1e-8809-\
3e5684009dcf"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"Lfermion", "=", 
  RowBox[{"I", " ", 
   RowBox[{"uvbar", ".", 
    RowBox[{"Ga", "[", "mu", "]"}], ".", 
    RowBox[{"DC", "[", 
     RowBox[{"uv", ",", "mu"}], "]"}]}]}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"-", "Muv"}], " ", 
   RowBox[{"uvbar", ".", "uv"}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.981691717720438*^9, 3.981691717722645*^9}},
 CellLabel->"In[73]:=",ExpressionUUID->"1c5f42a9-7d64-43d2-8130-bda33e60e552"],

Cell[BoxData[
 RowBox[{"\[ImaginaryI]", " ", 
  RowBox[{
   OverscriptBox["uv", "\<\"-\"\>"], ".", 
   TemplateBox[{"\[Gamma]", "mu"},
    "Superscript"], ".", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{
      RowBox[{"-", 
       FractionBox["2", "3"]}], " ", "\[ImaginaryI]", " ", 
      SubscriptBox["g", "1"], " ", "uv", " ", 
      SubscriptBox["B", "mu"]}], "+", 
     RowBox[{
      SubscriptBox["\<\"\[PartialD]\"\>", "mu"], "[", "uv", "]"}], "-", 
     RowBox[{"\[ImaginaryI]", " ", 
      SubscriptBox["g", "s"], " ", 
      RowBox[{
       SuperscriptBox["T", "PRIVATE`a$90248"], ".", "uv"}], " ", 
      SubscriptBox["G", 
       RowBox[{"mu", ",", "PRIVATE`a$90248"}]]}]}], ")"}]}]}]], "Output",
 CellChangeTimes->{3.981696442866794*^9},
 CellLabel->"Out[73]=",ExpressionUUID->"52e6ea2a-d494-400b-9fdb-c90a6fb69d2a"]
}, Open  ]],

