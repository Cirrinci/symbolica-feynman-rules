Cell[BoxData[
 RowBox[{
  RowBox[{"Lscalar", "=", 
   RowBox[{
    RowBox[{
     RowBox[{"1", "/", "2"}], "*", 
     RowBox[{"del", "[", 
      RowBox[{"pi1", ",", "mu"}], "]"}], 
     RowBox[{"del", "[", 
      RowBox[{"pi1", ",", "mu"}], "]"}]}], "-", 
    RowBox[{
     RowBox[{"1", "/", "2"}], "*", 
     RowBox[{"MM1", "^", "2"}], "*", 
     RowBox[{"pi1", "^", "2"}]}]}]}], ";"}]], "Input",
 CellChangeTimes->{{3.981691518929429*^9, 3.9816915304225388`*^9}, {
