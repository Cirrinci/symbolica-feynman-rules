Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
    "**", "**", "**", "**", "**", "**", "**", "**", "**", "**", "**", "**", "**",
      "**", "**"}], "*"}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"Full", " ", 
    RowBox[{"Lagrangian", ":", 
     RowBox[{"Feynman", " ", "rules"}]}]}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
    "**", "**", "**", "**", "**", "**", "**", "**", "**", "**", "**", "**", "**",
      "**", "**"}], "*"}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"verts", "=", 
     RowBox[{"FeynmanRules", "[", 
      RowBox[{"LSM", ",", 
       RowBox[{"FlavorExpand", "->", "True"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{
    "Convert", " ", "every", " ", "vertex", " ", "to", " ", "a", " ", 
     "structured", " ", "record"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"VertexData", "=", 
     RowBox[{"MapIndexed", "[", 
      RowBox[{
       RowBox[{"Function", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"vertex", ",", "index"}], "}"}], ",", 
         RowBox[{"Module", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"fields", ",", "legs"}], "}"}], ",", 
           RowBox[{
            RowBox[{"fields", "=", 
             RowBox[{
              RowBox[{
               RowBox[{"ToString", "[", 
                RowBox[{"#", ",", "InputForm"}], "]"}], "&"}], "/@", 
              RowBox[{"vertex", "[", 
               RowBox[{"[", 
                RowBox[{"1", ",", "All", ",", "1"}], "]"}], "]"}]}]}], ";", 
            "\[IndentingNewLine]", 
            RowBox[{"legs", "=", 
             RowBox[{
              RowBox[{
               RowBox[{"ToString", "[", 
                RowBox[{"#", ",", "InputForm"}], "]"}], "&"}], "/@", 
              RowBox[{"vertex", "[", 
               RowBox[{"[", "1", "]"}], "]"}]}]}], ";", "\[IndentingNewLine]", 
            RowBox[{"<|", 
             RowBox[{
              RowBox[{"\"\<id\>\"", "->", 
               RowBox[{"First", "[", "index", "]"}]}], ",", 
              RowBox[{"\"\<key\>\"", "->", 
               RowBox[{"StringRiffle", "[", 
                RowBox[{
                 RowBox[{"Sort", "[", "fields", "]"}], ",", "\"\<|\>\""}], 
                "]"}]}], ",", 
              RowBox[{"\"\<fields\>\"", "->", "fields"}], ",", 
              RowBox[{"\"\<legs\>\"", "->", "legs"}], ",", 
              RowBox[{"\"\<rule\>\"", "->", 
               RowBox[{"ToString", "[", 
                RowBox[{
                 RowBox[{"vertex", "[", 
                  RowBox[{"[", "2", "]"}], "]"}], ",", "InputForm"}], 
                "]"}]}]}], "|>"}]}]}], "]"}]}], "]"}], ",", "verts"}], 
      "]"}]}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
     "Sort", " ", "vertices", " ", "by", " ", "field", " ", "content"}], ",", 
     
     RowBox[{"without", " ", "changing", " ", "leg", " ", "order"}]}], "*)"}],
    "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"VertexData", "=", 
     RowBox[{"SortBy", "[", 
      RowBox[{"VertexData", ",", 
       RowBox[{
        RowBox[{"#", "[", "\"\<key\>\"", "]"}], "&"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{
    "Export", " ", "JSON", " ", "file", " ", "in", " ", "the", " ", 
     "notebook", " ", "folder"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"exportPath", "=", 
     RowBox[{"FileNameJoin", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"NotebookDirectory", "[", "]"}], 
        ",", "\"\<LSM_full_FeynRules.json\>\""}], "}"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"Export", "[", 
     RowBox[{"exportPath", ",", "VertexData", ",", "\"\<RawJSON\>\""}], "]"}],
     ";"}], "\[IndentingNewLine]", "\n", "exportPath"}]}]], "Input",
 CellChangeTimes->{{3.991811875337469*^9, 3.991811889655114*^9}, {
  3.991816072746665*^9, 3.9918160791049013`*^9}},
 CellLabel->"In[11]:=",ExpressionUUID->"a4048454-57fb-4697-aadb-fafd36457edc"],

